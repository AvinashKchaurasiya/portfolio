<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

    # 2. Redirect www to non-www
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301,NE]

    # 3. Handle Authorization Header (important for APIs)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # 4. Remove trailing slashes (optional, but SEO-friendly)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 5. Redirect all requests to public folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# 6. Disable directory listing
Options -Indexes

# 7. Block sensitive files
<FilesMatch "\.(env|git|env\.example|lock|htaccess|log|json|md|xml|yml|ini|conf|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "artisan|composer\.json|composer\.lock|\.gitignore">
    Order allow,deny
    Deny from all
</FilesMatch>
